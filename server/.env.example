# Server Configuration
PORT=5001
NODE_ENV=development
SCRAPER_SERVICE_URL=http://localhost:8000

# Database
# Provide your MongoDB connection URI (e.g. mongodb+srv://<user>:<password>@cluster.mongodb.net/dbname)
MONGODB_URI=your_mongodb_connection_uri_here

# Authentication
# Change JWT_SECRET to a long, complex, random string
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# Seed Data Credentials (Optional for local development)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_this_password123

# AI Summarization & ATS Score (Optional)
# Obtain an API key from openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Notifications (Optional - Nodemailer SMTP config)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password_here
EMAIL_FROM=your_email@gmail.com

# WhatsApp (Optional - Twilio setup for broadcasts)
TWILIO_SID=your_twilio_sid_here
TWILIO_AUTH=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=+14155238886
